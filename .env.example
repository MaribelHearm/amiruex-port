# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Transcribe (ASR) provider chain, comma-separated
TRANSCRIBE_PROVIDER_CHAIN=tencent_asr,azure_speech_asr,openai_asr,custom_asr_http
TRANSCRIBE_MAX_MINUTES=180
TRANSCRIBE_MAX_UPLOAD_MB=30
TRANSCRIBE_TIMEOUT_MS=900000

# OpenAI ASR fallback
TRANSCRIBE_API_KEY=
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe

# Tencent ASR primary
# 仅占位示例：请改成你当前新密钥，不要提交到 Git
TENCENT_ASR_SECRET_ID=REPLACE_WITH_TENCENT_SECRET_ID
TENCENT_ASR_SECRET_KEY=REPLACE_WITH_TENCENT_SECRET_KEY
TENCENT_ASR_REGION=ap-guangzhou

# Azure Speech ASR fallback
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Optional executable paths (for environments where PATH does not include yt-dlp/ffmpeg)
TRANSCRIBE_YTDLP_PATH=
TRANSCRIBE_FFMPEG_PATH=
TRANSCRIBE_FFPROBE_PATH=

# Custom ASR HTTP fallback
CUSTOM_ASR_ENDPOINT=
CUSTOM_ASR_TOKEN=
